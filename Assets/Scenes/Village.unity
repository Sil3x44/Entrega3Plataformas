    - target: {fileID: 9143125259491683700, guid: 91ce4f4893d61dd4199322eb2e7bb71e, type: 3}
      propertyPath: interactionPrompt
      value: 
      objectReference: {fileID: 1679804361}
    - target: {fileID: 9143125259491683700, guid: 91ce4f4893d61dd4199322eb2e7bb71e, type: 3}
      propertyPath: dialogueLines.Array.size
      value: 4
      objectReference: {fileID: 0}
    - target: {fileID: 9143125259491683700, guid: 91ce4f4893d61dd4199322eb2e7bb71e, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: "Has entrenado bien. Ya no queda mucho m\xE1s que pueda ense\xF1arte."
      objectReference: {fileID: 0}
    - target: {fileID: 9143125259491683700, guid: 91ce4f4893d61dd4199322eb2e7bb71e, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: "Si te sientes preparado, es hora de abandonar las monta\xF1as y descender
        a las minas."
      objectReference: {fileID: 0}
    - target: {fileID: 9143125259491683700, guid: 91ce4f4893d61dd4199322eb2e7bb71e, type: 3}
      propertyPath: 'dialogueLines.Array.data[2]'
      value: "Hace a\xF1os que el autoproclamado Rey Goblin, el Bar\xF3n Grumrak
        el Devorahuesos, se esconde all\xED abajo. Desde entonces, esqueletos y goblins
        no han dejado de atacar estas tierras."
      objectReference: {fileID: 0}
    - target: {fileID: 9143125259491683700, guid: 91ce4f4893d61dd4199322eb2e7bb71e, type: 3}
      propertyPath: 'dialogueLines.Array.data[3]'
      value: "Ve con cuidado. Y recuerda... tu mente es m\xE1s fuerte que una buena
        espada."
      objectReference: {fileID: 0}
